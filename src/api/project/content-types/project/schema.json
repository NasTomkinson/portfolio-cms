{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Projects"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "description": {
      "type": "text"
    },
    "roleType": {
      "type": "string"
    },
    "roleDuration": {
      "type": "string"
    },
    "descriptor": {
      "type": "component",
      "component": "composite.projects-descriptors",
      "repeatable": true
    },
    "languages": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "brandColour": {
      "type": "string"
    },
    "brandLogo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "brandLogos": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "introduction": {
      "type": "text"
    },
    "testimonial": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::testimonial.testimonial",
      "mappedBy": "project"
    }
  }
}
